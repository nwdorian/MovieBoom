{
    "Serilog": {
        "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.MSSqlServer"],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Information",
                "Microsoft.AspNetCore.StaticFiles": "Warning",
                "Microsoft.AspNetCore.StaticAssets": "Warning",
                "Microsoft.AspNetCore.Routing": "Warning",
                "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
                "System": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "Console"
            },
            {
                "Name": "MSSqlServer",
                "Args": {
                    "connectionString": "Default",
                    "sinkOptionsSection": {
                        "tableName": "Logs",
                        "schemaName": "EventLogging",
                        "autoCreateSqlDatabase": true,
                        "autoCreateSqlTable": true,
                        "batchPostingLimit": 1000,
                        "batchPeriod": "0.00:00:30"
                    }
                }
            }
        ],
        "Enrich": ["FromLogContext"]
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "Default": "Server=localhost,1433;Database=movieboom;User Id=sa;Password=Password123;Encrypt=false;TrustServerCertificate=true"
    },
    "Smtp": {
        "Host": "localhost",
        "Port": 1025,
        "EnableSsl": false,
        "FromAddress": "noreply@movieboom.com",
        "FromName": "MovieBoom"
    }
}
