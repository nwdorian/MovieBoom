@using Web.Models.Movies.Extensions
@model MovieIndex

@{
    ViewData["Title"] = "Home Page";
}


<div class="card mb-3">
    <div class="card-body movie-filters">
        <form id="filter-form" asp-controller="Home" asp-action="Index" method="get"
              class="d-flex flex-wrap gap-2 align-items-end">
            <button type="button" class="btn btn-primary" onclick="loadModal('Home', 'Create')">
                Add movie
            </button>

            <div class="movie-filter-search">
                <input id="search-input" class="form-control" type="text" name="SearchTerm"
                       value="@Model.Filter?.SearchTerm" placeholder="Find by title…" />
                <button type="submit" class="btn btn-primary">Search</button>
            </div>

            <div class="movie-filter-select">
                <label for="genres-dropdown">Genre:</label>
                <select class="form-select" id="genres-dropdown" name="GenreName" asp-items="Model.Genres"
                        onchange="this.form.submit()">
                    <option value="">All</option>
                </select>
            </div>

            <div class="movie-filter-price">
                <label for="start-price">Price:</label>
                <div class="d-flex gap-1">
                    <input id="start-price" class="form-control" type="number" name="StartPrice"
                           value="@Model.Filter?.StartPrice.ToString()" step="0.1" min="0" placeholder="From"
                           onblur="this.form.submit()" />
                    <input id="end-price" class="form-control" type="number" name="EndPrice"
                           value="@Model.Filter?.EndPrice.ToString()" step="0.1" min="0" placeholder="To"
                           onblur="this.form.submit()" />
                </div>
            </div>

            <div class="movie-filter-sort">
                <label for="sort-column">Sort:</label>
                <div class="d-flex gap-1">
                    <select id="sort-column" class="form-select" name="SortColumn" asp-items="Model.SortColumns"
                            onchange="this.form.submit()"></select>
                    <select class="form-select" name="SortOrder" asp-items="Model.SortOrders"
                            onchange="this.form.submit()"></select>
                </div>
            </div>
        </form>
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Movies[0].Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Movies[0].Genre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Movies[0].ReleaseDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Movies[0].Price)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Movies[0].Rating)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var movie in Model.Movies)
        {
            <tr>
                <td>
                    @Html.DisplayFor(model => movie.Title)
                </td>
                <td>
                    @Html.DisplayFor(model => movie.Genre)
                </td>
                <td>
                    @Html.DisplayFor(model => movie.ReleaseDate)
                </td>
                <td>
                    @Html.DisplayFor(model => movie.Price)
                </td>
                <td>
                    @Html.DisplayFor(model => movie.Rating)
                </td>
                <td class="text-end">
                    <button type="button" class="btn btn-outline-primary" onclick="loadModal('Home', 'Update', '@movie.Id')"
                            aria-label="Edit movie">
                        <i class="bi bi-pencil-square" aria-hidden="true"></i>
                    </button>
                    <button type="button" class="btn btn-outline-primary" onclick="loadModal('Home', 'Delete', '@movie.Id')"
                            aria-label="Delete movie">
                        <i class="bi bi-trash3" aria-hidden="true"></i>
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
    <ul class="pagination mb-0">
        <li class="page-item @(Model.PagingMetadata.HasPreviousPage ? "" : "disabled")">
            <a class="page-link" asp-action="Index" asp-all-route-data="@Model.ToPagingRouteValues()"
                   asp-route-pageNumber="@(Model.PagingMetadata.PageNumber - 1)">
                <i class="bi bi-caret-left-fill" aria-hidden="true"></i>
            </a>
        </li>
        @for (var i = Model.PagingMetadata.StartPage; i <= Model.PagingMetadata.EndPage; i++)
        {
            <li class="page-item @(i == Model.PagingMetadata.PageNumber ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-all-route-data="@Model.ToPagingRouteValues()"
                       asp-route-pageNumber="@i">
                    @i
                </a>
            </li>
        }
        <li class="page-item @(Model.PagingMetadata.HasNextPage ? "" : "disabled")">
            <a class="page-link" asp-action="Index" asp-all-route-data="@Model.ToPagingRouteValues()"
                   asp-route-pageNumber="@(Model.PagingMetadata.PageNumber + 1)">
                <i class="bi bi-caret-right-fill" aria-hidden="true"></i>
            </a>
        </li>
    </ul>
    <div class="d-flex align-items-center gap-2">
        <label for="page-size-dropdown" class="mb-0 text-nowrap">Page size:</label>
        <select class="form-select" id="page-size-dropdown" form="filter-form" name="PageSize"
                asp-items="Model.PageSizes" onchange="document.getElementById('filter-form').submit()">
        </select>
    </div>
</div>

<div id="modal-placeholder"></div>

@section Scripts {
    <script src="~/js/modalManager.js"></script>
}