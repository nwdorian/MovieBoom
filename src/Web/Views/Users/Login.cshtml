@model UserLogin

@{
    ViewData["Title"] = "Login";
    ViewData["BodyClass"] = "login-page";
}

<div class="d-flex justify-content-center">
    <div class="card login-card">
        <div class="card-body">
            <h1 class="card-title">Login</h1>
            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group">
                    <label asp-for="Email" class="control-label"></label>
                    <input asp-for="Email" placeholder="email@example.com" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Password" class="control-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="form-group form-check">
                    <label class="form-check-label">
                        <input class="form-check-input" asp-for="RememberMe" />
                        @Html.DisplayNameFor(model => model.RememberMe)
                    </label>
                </div>
                <div class="form-group mb-2">
                    <a asp-action="ForgotPassword">Forgot password?</a>
                </div>
                <div class="form-group mb-2">
                    <input type="submit" value="Log In" class="btn btn-primary w-100" />
                </div>
                <div class="form-group text-center">
                    <p>Don't have an account? <a asp-action="Register">Register here!</a></p>
                </div>
                <hr />
            </form>
            <form asp-action="DemoLogin" method="post" class="d-inline">
                <div class="form-group text-center">
                    <p>Want to explore first? Try a demo user!</p>
                    <button type="submit" class="btn btn-secondary">Member</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}