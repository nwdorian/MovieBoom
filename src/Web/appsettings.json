{
    "Serilog": {
        "Using": ["Serilog.Sinks.Console"],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Information",
                "Microsoft.AspNetCore.StaticFiles": "Warning",
                "Microsoft.AspNetCore.StaticAssets": "Warning",
                "Microsoft.AspNetCore.Routing": "Warning",
                "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
                "System": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "Console"
            }
        ],
        "Enrich": ["FromLogContext"]
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "Default": "Server=movieboom.database,1433;Database=movieboom;User Id=sa;Password=Password123;Encrypt=false;TrustServerCertificate=true"
    },
    "Smtp": {
        "Host": "movieboom.email",
        "Port": 1025,
        "EnableSsl": false,
        "FromAddress": "noreply@movieboom.com",
        "FromName": "MovieBoom"
    }
}
